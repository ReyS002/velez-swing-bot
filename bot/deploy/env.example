VELEZ_PUBLIC_HOST=velezbot.72.62.169.3.nip.io
VELEZ_WEBHOOK_SECRET=replace-with-a-long-random-token
VELEZ_APPROVAL_API_TOKEN=replace-with-a-separate-local-approval-token
VELEZ_DASHBOARD_AUTH_ENABLED=true
VELEZ_DASHBOARD_USERNAME=desk
VELEZ_DASHBOARD_PASSWORD=replace-with-a-long-random-dashboard-password
VELEZ_NOTIFY_ENABLED=false
VELEZ_NOTIFY_FILE=/app/data/guardrail_notifications.jsonl
VELEZ_NOTIFY_WEBHOOK_URL=
VELEZ_NOTIFY_DISCORD_WEBHOOK_URL=
VELEZ_NOTIFY_TELEGRAM_BOT_TOKEN=
VELEZ_NOTIFY_TELEGRAM_CHAT_ID=
VELEZ_NOTIFY_TELEGRAM_AUDIO_ENABLED=false
VELEZ_NOTIFY_TELEGRAM_AUDIO_MAX_CHARS=700
VELEZ_NOTIFY_TELEGRAM_AUDIO_TIMEOUT_SECONDS=20
VELEZ_NOTIFY_MIN_SEVERITY=warn
VELEZ_NOTIFY_COOLDOWN_SECONDS=1800
VELEZ_EXECUTE_ORDERS=false
VELEZ_DATA_DIR=/app/data
VELEZ_AUTO_STAGE_PROPOSED_ORDERS=true
VELEZ_REQUIRE_ORDER_APPROVAL=false
VELEZ_APPROVAL_TTL_MINUTES=30
VELEZ_LIFECYCLE_WARN_MISSING_STOP=true
VELEZ_LIFECYCLE_AUTORECORD_OUTCOMES=true
VELEZ_LIFECYCLE_FILL_LOOKBACK_DAYS=7
VELEZ_LIFECYCLE_ORDER_LIMIT=100
# Lot sizing is configured in bot/config.yaml. The default flow is:
# 1 lot = 25% of max trade risk, 4 lots = full configured risk cap.

APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets
APCA_API_DATA_URL=https://data.alpaca.markets

# Optional: enables ES/NQ/MES/MNQ futures scanning through Polygon futures aggregates.
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io

# Calendar panel feeds. Alpha Vantage powers watchlist earnings; the macro
# sources are free official calendars and can be overridden if an agency URL moves.
ALPHA_VANTAGE_API_KEY=
CALENDAR_FEED_TIMEOUT_SECONDS=8
CALENDAR_FEED_CACHE_SECONDS=21600
CALENDAR_EVENT_LOOKAHEAD_DAYS=45
CALENDAR_MACRO_FEEDS_ENABLED=true
BLS_CALENDAR_ICS_URL=https://www.bls.gov/schedule/news_release/bls.ics
BEA_CALENDAR_URL=https://www.bea.gov/news/schedule/full
CENSUS_CALENDAR_URL=https://www.census.gov/economic-indicators/calendar-listview.html
NYFED_CALENDAR_URL=https://www.newyorkfed.org/research/national_economy/nationalecon_cal.html
FOMC_CALENDAR_URL=https://www.federalreserve.gov/monetarypolicy/fomccalendars.htm

APPLE_MUSIC_TEAM_ID=your-10-character-team-id
APPLE_MUSIC_KEY_ID=your-media-services-key-id
APPLE_MUSIC_PRIVATE_KEY_PATH=/opt/stacks/velez-trading-bot/secrets/AuthKey_KEYID.p8
APPLE_MUSIC_TOKEN_TTL_HOURS=12
APPLE_MUSIC_TOKEN_ORIGINS=https://your-bot-domain.example

# Winston phone: AI brain. Keep rule_based for maximum safety, use ollama for
# a private local model, or use openai_compatible/deepseek for a cloud API.
WINSTON_LLM_PROVIDER=rule_based
WINSTON_LLM_BASE_URL=http://127.0.0.1:11434
# In the Docker Compose stack with the optional ollama profile, use:
# WINSTON_LLM_BASE_URL=http://ollama:11434
# For DeepSeek, use:
# WINSTON_LLM_PROVIDER=deepseek
# WINSTON_LLM_BASE_URL=https://api.deepseek.com/v1
# WINSTON_LLM_MODEL=deepseek-v4-flash
# WINSTON_LLM_API_KEY=your-deepseek-api-key
# WINSTON_LLM_THINKING=disabled
WINSTON_LLM_MODEL=qwen3:1.7b
WINSTON_LLM_TIMEOUT_SECONDS=20
WINSTON_LLM_MAX_TOKENS=120
WINSTON_LLM_TEMPERATURE=0.25
# Set false for thinking models so Winston returns a concise spoken answer
# instead of spending the response budget reasoning.
WINSTON_LLM_THINK=false
WINSTON_LLM_THINKING=
WINSTON_LLM_REASONING_EFFORT=
WINSTON_LLM_FALLBACK_PROVIDER=ollama
WINSTON_LLM_FALLBACK_BASE_URL=http://ollama:11434
WINSTON_LLM_FALLBACK_MODEL=qwen3:1.7b
WINSTON_LLM_FALLBACK_THINK=false
WINSTON_LLM_FALLBACK_MAX_TOKENS=120
WINSTON_LLM_FALLBACK_TIMEOUT_SECONDS=20

# Winston Research Mode can stay on the slower/smarter model while phone mode
# uses the faster model for quick call-and-response. On the VPS, DeepSeek Pro
# is the recommended cloud research lane.
WINSTON_RESEARCH_LLM_PROVIDER=ollama
WINSTON_RESEARCH_LLM_BASE_URL=http://ollama:11434
WINSTON_RESEARCH_LLM_MODEL=qwen3.5:2b
WINSTON_RESEARCH_LLM_API_KEY=
WINSTON_RESEARCH_THINKING=
WINSTON_RESEARCH_REASONING_EFFORT=
WINSTON_RESEARCH_THINK=false
WINSTON_RESEARCH_MAX_TOKENS=320
WINSTON_RESEARCH_CONTEXT_CHARS=7000
WINSTON_RESEARCH_TIMEOUT_SECONDS=120
WINSTON_RESEARCH_FALLBACK_PROVIDER=ollama
WINSTON_RESEARCH_FALLBACK_BASE_URL=http://ollama:11434
WINSTON_RESEARCH_FALLBACK_MODEL=qwen3.5:2b
WINSTON_RESEARCH_FALLBACK_THINK=false
WINSTON_RESEARCH_FALLBACK_MAX_TOKENS=320
WINSTON_RESEARCH_FALLBACK_TIMEOUT_SECONDS=120

# Winston Deep Research uses the same idea as Research Mode, but with a larger
# context and output budget for stronger prep memos.
WINSTON_DEEP_RESEARCH_LLM_PROVIDER=
WINSTON_DEEP_RESEARCH_LLM_BASE_URL=
WINSTON_DEEP_RESEARCH_LLM_MODEL=
WINSTON_DEEP_RESEARCH_LLM_API_KEY=
WINSTON_DEEP_RESEARCH_THINKING=
WINSTON_DEEP_RESEARCH_REASONING_EFFORT=
WINSTON_DEEP_RESEARCH_MAX_TOKENS=1400
WINSTON_DEEP_RESEARCH_CONTEXT_CHARS=11000
WINSTON_DEEP_RESEARCH_TIMEOUT_SECONDS=120

# Winston phone: server voice. Use browser for Web Speech fallback, or pockettts
# when the Hermes PocketTTS bridge is installed on the same host.
WINSTON_TTS_PROVIDER=browser
WINSTON_TTS_BASE_URL=http://127.0.0.1:8018/v1
# In the Docker Compose stack with the optional pockettts voice profile, use:
# WINSTON_TTS_PROVIDER=pockettts
# WINSTON_TTS_BASE_URL=http://pockettts:8000/v1
WINSTON_TTS_API_KEY=
WINSTON_TTS_VOICE=jarvis-intro1
WINSTON_TTS_MODEL=tts-1
WINSTON_TTS_TIMEOUT_SECONDS=90
