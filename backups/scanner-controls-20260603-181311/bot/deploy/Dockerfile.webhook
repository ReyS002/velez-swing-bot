FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY bot/deploy/requirements-webhook.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

COPY bot /app/bot

EXPOSE 8080

CMD ["python", "-m", "bot.main", "--config", "bot/config.yaml", "webhook", "--host", "0.0.0.0", "--port", "8080", "--execute"]
